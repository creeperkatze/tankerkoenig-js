{
    "name": "tankerkoenig-js",
    "version": "1.0.16",
    "description": "JavaScript API client for the Tankerkönig gas prices API",
    "type": "module",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist/"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "tsc",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "release:patch": "pnpm version patch && git push && git push --tags",
        "release:minor": "pnpm version minor && git push && git push --tags",
        "release:major": "pnpm version major && git push && git push --tags"
    },
    "keywords": [
        "tankerkoenig",
        "gas",
        "fuel",
        "prices",
        "germany",
        "api"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/creeperkatze/tankerkoenig-js"
    },
    "bugs": {
        "url": "https://github.com/creeperkatze/tankerkoenig-js/issues"
    },
    "author": "Creeperkatze",
    "license": "AGPL-3.0-only",
    "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
    "engines": {
        "node": ">=18"
    },
    "devDependencies": {
        "@types/node": "^25.9.1",
        "@vitest/coverage-v8": "^2.1.9",
        "typescript": "^5.9.3",
        "vitest": "^2.1.9"
    }
}
