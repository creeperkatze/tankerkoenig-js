{
    "name": "tankerkoenig-js",
    "version": "1.0.14",
    "description": "JavaScript API client for the Tankerkönig gas prices API",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist/"
    ],
    "scripts": {
        "build": "tsc",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "release:patch": "pnpm version patch && git push && git push --tags",
        "release:minor": "pnpm version minor && git push && git push --tags",
        "release:major": "pnpm version major && git push && git push --tags"
    },
    "keywords": [
        "tankerkoenig",
        "gas",
        "fuel",
        "prices",
        "germany",
        "api"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/creeperkatze/tankerkoenig-js"
    },
    "author": "Creeperkatze",
    "license": "AGPL-3.0-only",
    "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
    "engines": {
        "node": ">=18"
    },
    "devDependencies": {
        "@types/node": "^25.9.1",
        "@vitest/coverage-v8": "^2.1.9",
        "typescript": "^5.9.3",
        "vitest": "^2.1.9"
    }
}
