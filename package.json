{
    "name": "tankerkoenig-js",
    "version": "1.0.12",
    "description": "JavaScript API client for the Tankerkönig gas prices API",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "files": [
