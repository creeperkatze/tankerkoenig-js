    "packageManager": "pnpm@10.27.0",
    "engines": {
        "node": ">=18"
    },
    "devDependencies": {
        "@types/node": "^25.4.0",
        "tsx": "^4.19.3",
        "typescript": "^5.8.2"
    }
}
